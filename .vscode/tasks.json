{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Backend",
      "type": "shell",
      "command": "dotnet watch run --project ./PoolLeaderboard.Server/PoolLeaderboard.Server.csproj --launch-profile http -c Development",
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "Start Angular",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/poolleaderboard.client"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "ng serve",
          "endsPattern": "Watch mode enabled. Watching for file changes"
        }
      }
    }
  ]
}