{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Backend",
      "type": "shell",
      "command": "dotnet watch run --project ./PoolLeaderboard.Server/PoolLeaderboard.Server.csproj --launch-profile http -c Development",
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "Run Frontend",
      "type": "shell",
      "command": "npx ng serve --host=0.0.0.0",
      "options": {
        "cwd": "workspaces/PoolLeaderboard/poolleaderboard.client"
      },
      "problemMatcher": []
    }
  ]
}