{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug .NET Backend",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/PoolLeaderboard.Server/bin/Debug/net10.0/PoolLeaderboard.Server.dll",
      "cwd": "${workspaceFolder}/PoolLeaderboard.Server",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://0.0.0.0:5166",
        "ASPNETCORE_HOSTINGSTARTUPASSEMBLIES": ""
      },
      "sourceFileMap": {
        "/app": "${workspaceFolder}/PoolLeaderboard.Server"
      }
    },
    {
      "name": "Debug Angular Frontend",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:60125",
      "webRoot": "${workspaceFolder}/poolleaderboard.client/src",
      "preLaunchTask": "Start Angular"
    }
  ]
}
